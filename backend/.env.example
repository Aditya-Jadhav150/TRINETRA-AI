# PostgreSQL Connection (Supabase Pooler URI)
DATABASE_URL=postgresql://<username>.<project-id>:<password>@<host>:5432/postgres

# Neo4j Graph Database Credentials (e.g., Neo4j AuraDB)
NEO4J_URI=neo4j+s://<database-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<password>

# Qdrant Vector Database (Qdrant Cloud)
QDRANT_URL=https://<cluster-id>.australia-southeast1-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=<qdrant-api-key>

# Redis Caching (Upstash Redis)
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# JWT Security Secrets (Used for login token generation)
JWT_SECRET=generate-a-long-random-string-here
JWT_REFRESH_SECRET=generate-another-long-random-string-here

# Mode Configuration
APP_MODE=development
